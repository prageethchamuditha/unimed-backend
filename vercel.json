{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/student(.*)",
      "dest": "backend/index.py"
    },
    {
      "src": "/doctors(.*)",
      "dest": "backend/index.py"
    },
    {
      "src": "/labassistant(.*)",
      "dest": "backend/index.py"
    }
  ]
}
